{
  "name": "@foldkit/lustre-benchmark",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm build:naive && pnpm build:optimised",
    "build:naive": "vite build",
    "build:optimised": "BUILD_VARIANT=optimised vite build && mv dist/optimised/index.optimised.html dist/optimised/index.html",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "4.0.0-beta.66",
    "foldkit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
