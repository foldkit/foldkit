{
  "name": "@foldkit/oxlint-plugin",
  "version": "0.4.0",
  "description": "Oxlint rules for Foldkit applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./recommended.json": "./recommended.json",
    "./all.json": "./all.json"
  },
  "scripts": {
    "clean": "rimraf dist recommended.json all.json *.tsbuildinfo",
    "build": "pnpm run clean && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js && node scripts/generate-presets.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect-oxlint": "^0.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "effect": "4.0.0-beta.88",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "recommended.json",
    "all.json"
  ],
  "keywords": [
    "foldkit",
    "oxlint",
    "lint",
    "effect"
  ],
  "author": "Devin Jameson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foldkit/foldkit.git",
    "directory": "packages/oxlint-plugin-foldkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
