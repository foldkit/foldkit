{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["typedoc-entry.ts"],
  "tsconfig": "tsconfig.docs.json",
  "json": "../website/src/generated/api-ui.json",
  "pretty": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "BaseInitConfig",
    "BaseViewInputs",
    "Entry",
    "Model",
    "UpdateReturn",
    "ViewForItem"
  ]
}
