{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.build.json",
  "json": "../website/src/generated/api.json",
  "pretty": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "Dispatch",
    "ElementFunction",
    "VoidElementFunction",
    "Child",
    "PrintState",
    "Evolved",
    "StrictKeys",
    "BaseProgramConfig",
    "ManagedResourceTypeId",
    "BaseInitConfig",
    "BaseViewConfig",
    "UpdateReturn",
    "EvolveTransform",
    "BuildFn",
    "InferParsed",
    "ParserInput",
    "CompletedAdvanceFocus",
    "DevToolsPosition",
    "ChildModelOf",
    "ChildMessageOf",
    "Entry",
    "EntryBuilder",
    "EntryWithEquivalence",
    "EntryWithoutEquivalence",
    "SubscriptionBrand",
    "WithStep",
    "FilterOptions",
    "ViewConfig",
    "PropertyFactories",
    "EventFactories"
  ]
}
