{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.json",
  "json": "../website/src/generated/api.json",
  "pretty": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "SubscriptionConfig",
    "Dispatch",
    "ElementFunction",
    "VoidElementFunction",
    "Child",
    "PrintState",
    "Evolved",
    "StrictKeys",
    "BaseApplicationConfig",
    "BaseElementConfig",
    "ManagedResourceTypeId",
    "BaseInitConfig",
    "BaseViewConfig",
    "UpdateReturn",
    "EvolveTransform",
    "BuildFn",
    "InferParsed",
    "ParserInput",
    "CompletedFocusItems",
    "CompletedFocusButton",
    "CompletedLockScroll",
    "CompletedUnlockScroll",
    "CompletedSetupInert",
    "CompletedTeardownInert",
    "CompletedScrollIntoView",
    "CompletedClickItem",
    "CompletedAdvanceFocus",
    "CompletedFocusPanel",
    "AdvancedTransitionFrame",
    "EndedTransition",
    "DetectedButtonMovement",
    "CompletedFocusOption",
    "CompletedFocusTab",
    "DevtoolsMode",
    "DevtoolsPosition",
    "ResolveMessage"
