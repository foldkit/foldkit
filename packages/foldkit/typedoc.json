{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "tsconfig": "tsconfig.build.json",
  "json": "../website/src/generated/api.json",
  "pretty": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "SubscriptionConfig",
    "Dispatch",
    "ElementFunction",
    "VoidElementFunction",
    "Child",
    "PrintState",
    "Evolved",
    "StrictKeys",
    "BaseProgramConfig",
    "ManagedResourceTypeId",
    "BaseInitConfig",
    "BaseViewConfig",
    "UpdateReturn",
    "EvolveTransform",
    "BuildFn",
    "InferParsed",
    "ParserInput",
    "CompletedAdvanceFocus",
    "DevtoolsMode",
    "DevtoolsPosition",
    "ResolveMessage",
    "WithStep"
  ]
}
