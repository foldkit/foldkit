{
  "name": "website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter foldkit docs",
    "dev": "vite",
    "prebuild": "pnpm --filter foldkit docs",
    "build": "vite build",
    "preview": "vite preview",
    "pretypecheck": "pnpm --filter foldkit docs",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "lint": "eslint .",
    "test": "vitest run",
    "prerender": "tsx scripts/prerender.ts",
    "postprerender": "pagefind",
    "preview:search": "pnpm build && pnpm prerender && vite preview"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@effect/platform-browser": "^0.74.0",
    "@tailwindcss/vite": "^4.1.18",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "effect": "^3.19.19",
    "foldkit": "workspace:*",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@effect/platform-node": "^0.104.1",
    "@eslint/js": "^9.39.2",
    "@foldkit/vite-plugin": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.2",
    "pagefind": "^1.3.0",
    "playwright": "^1.51.0",
    "prettier": "^3.8.1",
    "satori": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
