{
  "name": "@foldkit/vite-plugin",
  "version": "0.11.0",
  "description": "Vite plugin for Foldkit hot module reloading with state preservation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "pnpm run clean && tsc -b",
    "watch": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.97",
    "foldkit": "workspace:^0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "effect": "4.0.0-beta.97",
    "foldkit": "workspace:*",
    "happy-dom": "^20.10.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "foldkit",
    "hmr",
    "hot-reload"
  ],
  "author": "Devin Jameson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foldkit/foldkit.git",
    "directory": "packages/vite-plugin-foldkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
