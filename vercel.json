{
  "installCommand": "echo 'Dependencies already installed in CI'",
  "buildCommand": "echo 'Build already completed in CI'",
  "outputDirectory": "packages/website/dist",
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "embedded" }],
      "destination": "/example-apps-embed/:embedded/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
