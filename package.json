{
  "name": "foldkit-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "foldkit: Elm-inspired UI framework powered by Effect-TS",
  "scripts": {
    "prepare": "test -z \"$CI\" && simple-git-hooks || true",
    "check": "pnpm -r typecheck && pnpm lint",
    "lint": "pnpm -r --if-present lint",
    "check:changeset-ignore": "tsx scripts/check-changeset-ignore.ts",
    "pre-push": "pnpm format:check && pnpm check && pnpm test && pnpm check:changeset-ignore && pnpm changeset status --since=origin/main",
    "test": "pnpm -r --filter './examples/*' --filter './packages/*' run --if-present test",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "dev:core": "pnpm --filter foldkit watch",
    "dev:website": "pnpm --filter website dev",
    "build:examples": "bash scripts/build-examples.sh",
    "build:website": "pnpm --filter website... build",
    "dev:typing-game:client": "pnpm --filter @typing-game/client dev",
    "build:typing-game:client": "pnpm --filter @typing-game/client... build",
    "dev:typing-game:server": "pnpm --filter @typing-game/server dev",
    "build:typing-game": "pnpm --filter '@typing-game/*' build",
    "dev:example:counter": "pnpm --filter counter-example dev",
    "dev:example:stopwatch": "pnpm --filter stopwatch-example dev",
    "dev:example:weather": "pnpm --filter weather-example dev",
    "dev:example:todo": "pnpm --filter todo-example dev",
    "dev:example:form": "pnpm --filter form-example dev",
    "dev:example:routing": "pnpm --filter routing-example dev",
    "dev:example:query-sync": "pnpm --filter query-sync-example dev",
    "dev:example:shopping-cart": "pnpm --filter shopping-cart-example dev",
    "dev:example:snake": "pnpm --filter snake-example dev",
    "dev:example:websocket-chat": "pnpm --filter websocket-chat-example dev",
    "dev:example:auth": "pnpm --filter auth-example dev",
    "dev:example:error-view": "pnpm --filter error-view-example dev",
    "dev:example:ui-showcase": "pnpm --filter ui-showcase dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@eslint/js": "^9.39.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "effect": "^3.19.19",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "simple-git-hooks": {
    "pre-push": "exec pnpm pre-push"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract",
      "simple-git-hooks"
    ],
    "overrides": {
      "effect": "^3.19.19",
      "@effect/platform": "^0.94.5",
      "@effect/platform-browser": "^0.74.0",
      "@effect/platform-node": "^0.104.1",
      "@effect/rpc": "^0.73.0",
      "@effect/cli": "^0.73.2",
      "@effect/vitest": "^0.27.0"
    }
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "pnpm": ">=8"
  },
  "keywords": [
    "effect",
    "ui",
    "elm",
    "functional",
    "typescript",
    "framework"
  ],
  "author": "Devin Jameson",
  "license": "MIT"
}
